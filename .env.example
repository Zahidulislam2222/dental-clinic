# ═══════════════════════════════════════════════════════════════
# Everyday Dental Surgery — Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your credentials below
#   3. Restart the dev server after changes:  npm run dev
#   4. For Cloudflare Pages: add these in Dashboard → Settings → Environment Variables
#
# SUPABASE SETUP:
#   1. Upgrade to Supabase Pro plan ($25/mo) and sign BAA
#   2. Go to Settings → API to find your URL and anon key
#   3. Enable extensions: pgcrypto, pg_cron, vault
#   4. Run migrations 001-009 in order via SQL Editor
#   5. Set server-side secrets via: supabase secrets set KEY=value
#
# ═══════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED — client-side, safe to expose) ──
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ═══════════════════════════════════════════════════════════════
# SERVER-SIDE ONLY — set via: supabase secrets set KEY=value
# DO NOT put these in .env or commit them anywhere
# ═══════════════════════════════════════════════════════════════
#
# PHI_ENCRYPTION_KEY=          # 256-bit hex key for pgcrypto
# RESEND_API_KEY=              # From resend.com (sign BAA first)
# CLINIC_NOTIFICATION_EMAIL=   # Admin email for notifications
# BREACH_NOTIFICATION_EMAIL=   # Security officer email
# SITE_URL=                    # Your production URL (e.g. https://everyday-dental.com)
